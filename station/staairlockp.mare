@@ Station Airlock Parent v0.1
@@  solar/station/staairlockp
@@      Station airlocks

@echo [ansi(y+,{WARNING: This links to 0.0.0, NOT the location of the station.})]

@addparent2 Station Airlock Parent=Multi-Dimension Coordinate System Parent

@set Station Airlock Parent=Color:[get(loc(me),color)]
@set Station Airlock Parent=Vlink:[get(zone(loc(me)),space)]:[plane3d(0,0,0)]
