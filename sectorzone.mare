@@ Sector Zone Parent v1.0

@set Sector Zone Parent=haven
@addparent Sector Zone Parent=System Function Parent

@@ When someone leaves, reset their plane to 0
@set Sector zone Parent=Aleave:@tel %#=[loc(v(#))]:0

@defattr Sector Zone Parent/cmd_warp=inherit
@set Sector Zone Parent=Cmd_warp:$warp *.*.*:/[haspow(owner(v(#)),teleport)]/@tel %#=[loc(v(#))]:[enccoord(v(0),v(1),v(2))]
