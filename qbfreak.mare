@addparent me=Comtitle Manager Parent
@@addparent me=Foo
@addparent me=Player Character Parent
@@addparent me=System Function Parent

@defattr me/cmd_limbo
@defattr me/cmd_lab
@defattr me/cmd_loopback
@defattr me/cmd_parenthome
@defattr me/cmd_drd
@defattr me/cmd_drd_enable
@defattr me/cmd_drd_disable
